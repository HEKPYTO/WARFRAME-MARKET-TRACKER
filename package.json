{
  "name": "@warframe-market-tracker/root",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:web && bun run build:worker",
    "build:web": "bun run --cwd apps/web build",
    "build:worker": "bun run --cwd apps/worker build",
    "check": "bun run lint && bun run typecheck && bun run test && bun run test:e2e && bun run build",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:worker": "bun run --cwd apps/worker dev",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "test:e2e": "bash ./scripts/run-e2e.sh",
    "test": "bun test packages apps/web/src apps/worker/src",
    "typecheck:worker-health": "bun run --cwd packages/worker-health typecheck",
    "typecheck:alert-engine": "bun run --cwd packages/alert-engine typecheck",
    "typecheck:db": "bun run --cwd packages/db typecheck",
    "typecheck:discord-client": "bun run --cwd packages/discord-client typecheck",
    "typecheck:discord-alerts": "bun run --cwd packages/discord-alerts typecheck",
    "typecheck:market-client": "bun run --cwd packages/market-client typecheck",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "typecheck:worker": "bun run --cwd apps/worker typecheck",
    "typecheck": "bun run typecheck:web && bun run typecheck:worker && bun run typecheck:worker-health && bun run typecheck:alert-engine && bun run typecheck:db && bun run typecheck:discord-client && bun run typecheck:discord-alerts && bun run typecheck:market-client",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/bun": "^1.2.8",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
